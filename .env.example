# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/supadash
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=supadash

# ─── Auth ─────────────────────────────────────────────────
ALLOW_SIGNUP=true
JWT_SECRET=change-me-to-a-64-char-random-string
ENCRYPTION_SECRET=change-me-to-a-32-char-string

# ─── API Security ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_REQUESTS=100

# ─── SMTP (Team Invitations) ─────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ─── Studio ──────────────────────────────────────────────
DOMAIN_STUDIO_URL=http://localhost:3000
DOMAIN_BASE=supamanager.io

# ─── Service Versions ────────────────────────────────────
SERVICE_VERSION_URL=https://supamanager.io/updates

# ─── Postgres Defaults ───────────────────────────────────
POSTGRES_DISK_SIZE=10
POSTGRES_DEFAULT_VERSION=14.2
POSTGRES_DOCKER_IMAGE=supabase/postgres

# ─── DNS Hook ────────────────────────────────────────────
DOMAIN_DNS_HOOK_URL=http://localhost:8081
DOMAIN_DNS_HOOK_KEY=mysecretkey

# ─── Provisioning ────────────────────────────────────────
PROVISIONING_ENABLED=true
PROVISIONING_DOCKER_HOST=unix:///var/run/docker.sock
PROVISIONING_PROJECTS_DIR=./projects
PROVISIONING_BASE_POSTGRES_PORT=5433
PROVISIONING_BASE_KONG_HTTP_PORT=54321